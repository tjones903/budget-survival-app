<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Life Mode</title>

<style>
body {
  margin: 0;
  font-family: system-ui;
  background: radial-gradient(circle at top, #0f2027, #0f0f0f);
  color: white;
}

.header {
  text-align: center;
  padding: 20px;
  font-size: 24px;
  font-weight: bold;
  text-shadow: 0 0 10px #00ffcc;
}

.nav {
  display: flex;
  justify-content: space-around;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(10px);
  padding: 12px;
}

.nav a {
  color: #00e676;
  text-decoration: none;
}

.container {
  padding: 20px;
  max-width: 500px;
  margin: auto;
}

.card {
  background: rgba(30,30,30,0.6);
  backdrop-filter: blur(15px);
  padding: 20px;
  border-radius: 16px;
  margin-bottom: 15px;
  box-shadow: 0 0 15px rgba(0,255,200,0.2);
  animation: fadeIn 0.6s ease;
}

button {
  width: 100%;
  padding: 15px;
  margin-top: 10px;
  border-radius: 12px;
  border: none;
  font-size: 16px;
  color: white;
  transition: 0.3s;
}

button:hover {
  transform: scale(1.05);
  box-shadow: 0 0 15px rgba(0,255,200,0.5);
}

/* MODE COLORS */
.broke { background: linear-gradient(45deg, red, #ff5252); }
.hustle { background: linear-gradient(45deg, orange, #ff9800); }
.stable { background: linear-gradient(45deg, #00c853, #00e676); }
.emergency { background: linear-gradient(45deg, purple, #9c27b0); }

.result {
  margin-top: 15px;
  font-size: 16px;
  line-height: 1.6;
  white-space: pre-line;
}

/* ANIMATION */
@keyframes fadeIn {
  from {opacity:0; transform:translateY(10px);}
  to {opacity:1; transform:translateY(0);}
}
</style>
</head>

<body>

<div class="header">🧠 Life Mode</div>

<div class="nav">
  <a href="index.html">Home</a>
  <a href="flip.html">Flip</a>
  <a href="about.html">About</a>
</div>

<div class="container">

<div class="card">
  <h3>Select Your Mode</h3>

  <button class="broke" onclick="setMode('broke')">💸 Broke Mode</button>
  <button class="hustle" onclick="setMode('hustle')">🔥 Hustle Mode</button>
  <button class="stable" onclick="setMode('stable')">🧘 Stability Mode</button>
  <button class="emergency" onclick="setMode('emergency')">🚨 Emergency Mode</button>

  <div id="output" class="result"></div>
</div>

<div class="card">
  <button onclick="goBack()">⬅ Back to Budget</button>
</div>

</div>

<script>
function setMode(mode) {
  let message = "";

  if (mode === "broke") {
    message = `
💸 BROKE MODE

Spend: Under $15 today

Action:
• Flip 1 item
• Sell something you own

Warning:
You are at risk of running out
    `;
  }

  if (mode === "hustle") {
    message = `
🔥 HUSTLE MODE

Goal: Make $100 today

Action:
• Flip item
• Offer a service
• Sell something fast

Stay active and move fast
    `;
  }

  if (mode === "stable") {
    message = `
🧘 STABILITY MODE

Spend normally

Action:
• Save money
• Avoid waste

You are in a good position
    `;
  }

  if (mode === "emergency") {
    message = `
🚨 EMERGENCY MODE

Stop spending now

Action:
• Sell 1–2 items
• Cut expenses
• Find quick cash

Priority: survival
    `;
  }

  document.getElementById("output").innerText = message;
}

function goBack() {
  window.location.href = "index.html";
}
</script>

</body>
</html>
